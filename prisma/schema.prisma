generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PARENT
  CONSULTANT
  SCHOOL
  SUPER_ADMIN
}

enum Track {
  SPECIAL_12YR // 12년 특례
  SPECIAL_3YR  // 3년 특례
}

enum DocumentType {
  APPLICATION     // 1. 입학원서
  ATTENDANCE      // 2, 3, 6. 수락기간, 해외학교기록, 재학사실증명
  CONSENT         // 4. 학력조회동의서
  TRANSCRIPT      // 5. 성적증명 (SPEC)
  GRADUATION      // 7. 졸업증명
  LANGUAGE        // 8. 한국어능력 (SPEC)
  QUALIFICATION   // 9. 출입국사실증명
  PASSPORT        // 10. 여권사본
  ACTIVITY        // 11. 비교과활동 (SPEC)
  ACTIVITY_LIST   // 12. 서류목록표
  TEST_SCORE      // 13. 표준화학력평가 (SPEC)
  SCHOOL_INFO     // 14. 학사일정표
  SCHOOL_PROFILE  // 15. 고교 프로파일 (SPEC_CONTEXT)
  OTHER
}

enum AccessLevel {
  VIEW
  EDIT
}

// ── 1. USERS ──
model User {
  id         String   @id @default(cuid())
  role       Role     @default(STUDENT)
  email      String   @unique
  fullName   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  studentProfile     StudentProfile?       @relation("StudentToUser")
  parentOf           StudentProfile[]      @relation("ParentToStudent")
  consultantStudents ConsultantStudent[]   @relation("ConsultantToMap")
  uploadedDocs       Document[]            @relation("UploaderToDocument") // 교사가 직접 올린 경우 추적
}

// ── 2. STUDENT PROFILES ──
model StudentProfile {
  userId     String  @id
  user       User    @relation("StudentToUser", fields: [userId], references: [id], onDelete: Cascade)
  
  parentId   String?
  parent     User?   @relation("ParentToStudent", fields: [parentId], references: [id], onDelete: SetNull)

  track      Track?
  status     String  @default("ONBOARDING") // ONBOARDING, OCR_REVIEW, EVALUATION, STORY_BUILDER, FINALIZED

  // Persistence for work-in-progress state
  selectedThemeId   String?
  storyAnswer       String? @db.Text
  
  // Academic & Activity Profile
  gpa               Float?
  academicRecords   AcademicRecord[]
  activities        Activity[]
  
  // Relations
  documents     Document[]
  essays        Essay[]
  applications  UniversityApplication[] // New: University-specific application slots
  consultants   ConsultantStudent[] @relation("StudentToMap")
}

// ── 2.5. ACADEMIC & ACTIVITY RECORDS ──
model AcademicRecord {
  id               String         @id @default(cuid())
  studentId        String
  student          StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  
  subject          String
  grade            String
  credit           Int            @default(1)
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Activity {
  id               String         @id @default(cuid())
  studentId        String
  student          StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  
  title            String
  description      String         @db.Text
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ── 3. UNIVERSITY APPLICATIONS (Per-school Slot) ──
model UniversityApplication {
  id           String       @id @default(cuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  guidelineId  String
  guideline    UniversityGuideline @relation(fields: [guidelineId], references: [id])

  status       String       @default("DRAFT") // DRAFT, READY, SUBMITTED
  
  // School-specific AI insights
  evaluationResult  Json?   // AI spec evaluation result specific to THIS university
  
  // Snapshotted checklist status
  submissionStatus  Json?   // Computed status of required documents

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([studentId, guidelineId]) // One slot per university per student
}

// ── 4. DOCUMENTS (OCR & STORAGE) ──
model Document {
  id           String       @id @default(cuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  uploaderId   String
  uploader     User         @relation("UploaderToDocument", fields: [uploaderId], references: [id]) 

  type         DocumentType
  storagePath  String       
  ocrData      Json?        
  isApproved   Boolean      @default(false)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ── 5. ESSAYS (자소서 파이프라인) ──
model Essay {
  id             String       @id @default(cuid())
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  guidelineId    String
  guideline      UniversityGuideline @relation(fields: [guidelineId], references: [id])

  masterEn       String?      @db.Text
  masterKo       String?      @db.Text
  tailoredResult String?      @db.Text
  
  factWarnings   Json?        
  
  chatSessions   ChatSession[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── 6. CONSULTANT-STUDENT MAPPING (B2B 권한) ──
model ConsultantStudent {
  consultantId String
  consultant   User         @relation("ConsultantToMap", fields: [consultantId], references: [id], onDelete: Cascade)

  studentId    String
  student      StudentProfile @relation("StudentToMap", fields: [studentId], references: [userId], onDelete: Cascade)

  accessLevel  AccessLevel  @default(VIEW)
  createdAt    DateTime     @default(now())

  @@id([consultantId, studentId]) 
}

enum Intake {
  MARCH
  SEPTEMBER
}

// ── 7. UNIVERSITY GUIDELINES (관리자용) ──
model UniversityGuideline {
  id           String       @id
  university   String
  major        String
  intake       Intake       @default(MARCH) 
  requirements Json         
  isActive     Boolean      @default(true)

  applications UniversityApplication[]
  essays       Essay[]
}

// ── 8. CHAT & AI INTERACTION ──
enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model ChatSession {
  id        String   @id @default(cuid())
  essayId   String
  essay     Essay    @relation(fields: [essayId], references: [id], onDelete: Cascade)
  
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id            String      @id @default(cuid())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role          MessageRole
  content       String      @db.Text
  metadata      Json?       
  
  createdAt     DateTime    @default(now())
}
