generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ENUMS ──

enum Role {
  STUDENT
  ADMIN
}

enum Track {
  SPECIAL_12YR // 12년 특례
  SPECIAL_3YR  // 3년 특례
}

enum AnalysisStatus {
  PENDING
  ANALYZING
  DONE
  ERROR
}

enum MessageRole {
  user
  assistant
  system
}

// ── 1. USERS ──

model User {
  id        String   @id @default(cuid())
  role      Role     @default(STUDENT)
  email     String   @unique
  fullName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  spec          StudentSpec?
  essaySessions EssaySession[]
}

// ── 2. STUDENT SPEC ──
// 학생의 모든 스펙 정보를 한 곳에 통합 관리.
// 점수뿐 아니라 활동, 수상, 체류기간, 인적사항 등 모든 것을 포함.

model StudentSpec {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  track  Track?

  // 업로드된 문서 목록
  documents SpecDocument[]

  // AI가 모든 문서를 통합 분석한 결과 (자동 갱신)
  // 구조: { persona, academic, activities, awards, tests, residency, personalInfo }
  analysisResult Json?
  analysisStatus AnalysisStatus @default(PENDING)
  lastAnalyzedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 3. SPEC DOCUMENTS ──
// 학생이 업로드한 원본 파일들 (성적표, 활동증명, 여권 등 모두 포함)

model SpecDocument {
  id       String      @id @default(cuid())
  specId   String
  spec     StudentSpec @relation(fields: [specId], references: [userId], onDelete: Cascade)

  fileName    String
  storagePath String
  mimeType    String
  fileSize    Int      @default(0)

  // Upstage/GPT-4o OCR 결과 원문
  ocrText     String?  @db.Text

  // 이 문서에서 추출된 구조화 데이터 (개별 문서 단위)
  parsedData  Json?

  isProcessed Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 4. ESSAY SESSIONS ──
// 대학별 챗봇 대화 + 자소서 초안을 하나의 세션으로 통합 관리.
// mode: 'chat' = 자유 상담, 'essay' = 자소서 작성 중심

model EssaySession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 대학 식별자 (lib/university-meta.ts 의 slug와 일치)
  universitySlug String

  // 'chat' | 'essay'
  mode String @default("chat")

  messages   EssayMessage[]
  essayDraft String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, universitySlug])
}

// ── 5. ESSAY MESSAGES ──

model EssayMessage {
  id        String       @id @default(cuid())
  sessionId String
  session   EssaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role    MessageRole
  content String      @db.Text

  // AI 메타데이터 (토큰 수, 모델명 등)
  metadata Json?

  createdAt DateTime @default(now())
}
