generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  PARENT
  CONSULTANT
  SCHOOL
  SUPER_ADMIN
}

enum Track {
  SPECIAL_12YR // 12년 특례
  SPECIAL_3YR  // 3년 특례
}

enum DocumentType {
  APPLICATION     // 1. 입학원서
  ATTENDANCE      // 2, 3, 6. 수락기간, 해외학교기록, 재학사실증명
  CONSENT         // 4. 학력조회동의서
  TRANSCRIPT      // 5. 성적증명 (SPEC)
  GRADUATION      // 7. 졸업증명
  LANGUAGE        // 8. 한국어능력 (SPEC)
  QUALIFICATION   // 9. 출입국사실증명
  PASSPORT        // 10. 여권사본
  ACTIVITY        // 11. 비교과활동 (SPEC)
  ACTIVITY_LIST   // 12. 서류목록표
  TEST_SCORE      // 13. 표준화학력평가 (SPEC)
  SCHOOL_INFO     // 14. 학사일정표
  SCHOOL_PROFILE  // 15. 고교 프로파일 (SPEC_CONTEXT)
  OTHER
}

enum AccessLevel {
  VIEW
  EDIT
}

// ── 1. USERS ──
model User {
  id         String   @id @default(cuid())
  role       Role     @default(STUDENT)
  email      String   @unique
  fullName   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  studentProfile     StudentProfile?       @relation("StudentToUser")
  parentOf           StudentProfile[]      @relation("ParentToStudent")
  consultantStudents ConsultantStudent[]   @relation("ConsultantToMap")
  uploadedDocs       Document[]            @relation("UploaderToDocument") // 교사가 직접 올린 경우 추적
}

// ── 2. STUDENT PROFILES ──
model StudentProfile {
  userId     String  @id
  user       User    @relation("StudentToUser", fields: [userId], references: [id], onDelete: Cascade)
  
  parentId   String?
  parent     User?   @relation("ParentToStudent", fields: [parentId], references: [id], onDelete: SetNull)

  track      Track?
  status     String  @default("ONBOARDING") // ONBOARDING, OCR_REVIEW, EVALUATION, STORY_BUILDER, FINALIZED

  // Persistence for work-in-progress state
  selectedThemeId   String?
  storyAnswer       String? @db.Text
  targetGuidelineIds String[] 
  evaluationResult  Json?   // AI spec evaluation results (strengths, weaknesses, etc.)

  // Relations
  documents  Document[]
  essays     Essay[]
  consultants ConsultantStudent[] @relation("StudentToMap")
}

// ── 3. DOCUMENTS (OCR & STORAGE) ──
model Document {
  id           String       @id @default(cuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  uploaderId   String
  uploader     User         @relation("UploaderToDocument", fields: [uploaderId], references: [id]) // 업로더 추적 (학생 본인 or 학교 교사)

  type         DocumentType
  storagePath  String       // Supabase Storage 경로
  ocrData      Json?        // Upstage AI가 파싱한 결과물
  isApproved   Boolean      @default(false)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ── 4. ESSAYS (자소서 파이프라인) ──
model Essay {
  id             String       @id @default(cuid())
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [userId], onDelete: Cascade)

  guidelineId    String
  guideline      UniversityGuideline @relation(fields: [guidelineId], references: [id])

  masterEn       String?      @db.Text
  masterKo       String?      @db.Text
  tailoredResult String?      @db.Text
  
  factWarnings   Json?        // 팩트체크 경고 내역 (오류가 없으면 null 또는 빈 배열)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ── 5. CONSULTANT-STUDENT MAPPING (B2B 권한) ──
model ConsultantStudent {
  consultantId String
  consultant   User         @relation("ConsultantToMap", fields: [consultantId], references: [id], onDelete: Cascade)

  studentId    String
  student      StudentProfile @relation("StudentToMap", fields: [studentId], references: [userId], onDelete: Cascade)

  accessLevel  AccessLevel  @default(VIEW)
  createdAt    DateTime     @default(now())

  @@id([consultantId, studentId]) // 복합 키 (Composite Key)
}

// ── 6. UNIVERSITY GUIDELINES (관리자용) ──
model UniversityGuideline {
  id           String       @id
  university   String
  major        String
  requirements Json         // 문항, 글자수 제한, 필수 키워드 등
  isActive     Boolean      @default(true)

  essays       Essay[]
}
